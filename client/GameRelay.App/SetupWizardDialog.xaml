<ContentDialog
    x:Class="GameRelay.App.SetupWizardDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Set up your relay server"
    PrimaryButtonText="Save &amp; connect"
    CloseButtonText="Close"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="False">

    <ScrollViewer MaxHeight="560" Padding="2,0,10,0">
        <StackPanel Spacing="14" MinWidth="440">

            <!-- prerequisites -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="Don't have a server yet? (free Oracle Cloud VM)" FontWeight="SemiBold" />
                </Expander.Header>
                <StackPanel Spacing="6" Padding="0,4,0,4">
                    <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        Oracle Cloud gives a free-forever VM. Quick version:
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        1. Sign up at signup.oraclecloud.com (a card is needed for verification only).
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        2. Networking → Virtual Cloud Networks → Start VCN Wizard →
                        "Create VCN with Internet Connectivity" → name it → Next → Create.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        3. Compute → Instances → Create instance. Image: Ubuntu 24.04, Shape:
                        VM.Standard.A1.Flex (Always Free). Under Networking pick that VCN's public
                        subnet and set "Assign a public IPv4 address" = Yes.
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        4. Add SSH keys → "Generate a key pair for me" → Save private key (keep it!).
                        Create, then copy the instance's Public IP address.
                    </TextBlock>
                </StackPanel>
            </Expander>

            <!-- mode selection -->
            <TextBlock Text="How do you want to install the relay?" FontWeight="SemiBold" />
            <RadioButton x:Name="AutoRadio" GroupName="mode" Checked="Mode_Changed"
                         Content="Automatic — the app installs it for me over SSH  (recommended)" />
            <RadioButton x:Name="ManualRadio" GroupName="mode" Checked="Mode_Changed"
                         Content="Manual — I'll run the commands myself" />

            <!-- ===================== AUTOMATIC ===================== -->
            <StackPanel x:Name="AutoPanel" Spacing="12"
                        Padding="16" CornerRadius="10"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <TextBox x:Name="AutoHostBox" Header="Server public IP address"
                         PlaceholderText="140.10.20.30" TextChanged="AnyAuto_Changed" />
                <TextBox x:Name="AutoUserBox" Header="SSH username" Text="ubuntu" TextChanged="AnyAuto_Changed" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="AutoKeyBox" Grid.Column="0" Header="SSH private key file"
                             PlaceholderText="the .key file Oracle gave you" IsReadOnly="True" />
                    <Button x:Name="BrowseKeyButton" Grid.Column="1" Content="Browse…"
                            VerticalAlignment="Bottom" Click="BrowseKey_Click" />
                </Grid>
                <Button x:Name="ProvisionButton" Style="{StaticResource AccentButtonStyle}"
                        Click="Provision_Click" IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ProgressRing x:Name="ProvisionSpinner" Width="16" Height="16"
                                      IsActive="False" Visibility="Collapsed" />
                        <FontIcon x:Name="ProvisionIcon" Glyph="&#xE753;" FontSize="14" />
                        <TextBlock x:Name="ProvisionLabel" Text="Install relay on server" />
                    </StackPanel>
                </Button>
                <Border x:Name="LogBorder" Visibility="Collapsed"
                        Background="#0A0E13" CornerRadius="8" Padding="10" MaxHeight="150">
                    <ScrollViewer x:Name="LogScroll">
                        <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="11.5"
                                   TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                   Foreground="#7EE2B8" />
                    </ScrollViewer>
                </Border>
                <InfoBar x:Name="AutoResult" IsOpen="False" IsClosable="False" />
            </StackPanel>

            <!-- ===================== MANUAL ===================== -->
            <StackPanel x:Name="ManualPanel" Spacing="12" Visibility="Collapsed"
                        Padding="16" CornerRadius="10"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <TextBox x:Name="ManualHostBox" Header="Server public IP address"
                         PlaceholderText="140.10.20.30" TextChanged="AnyManual_Changed" />
                <TextBlock Text="1 · From the bundle folder, run these in PowerShell (replace the key path):"
                           TextWrapping="Wrap" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0A0E13" CornerRadius="8" Padding="10">
                        <TextBlock x:Name="ManualCmd" FontFamily="Consolas" FontSize="11.5"
                                   TextWrapping="Wrap" IsTextSelectionEnabled="True" Foreground="#7EE2B8" />
                    </Border>
                    <Button Grid.Column="1" VerticalAlignment="Top" Click="CopyManualCmd_Click"
                            ToolTipService.ToolTip="Copy">
                        <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                    </Button>
                </Grid>
                <TextBlock Text="2 · The installer prints a shared secret at the end. Paste it here:"
                           TextWrapping="Wrap" />
                <TextBox x:Name="ManualSecretBox" Header="Shared secret" PlaceholderText="paste the secret"
                         TextChanged="AnyManual_Changed" />
            </StackPanel>

            <!-- ===================== SECURITY LIST (always) ===================== -->
            <Expander x:Name="FirewallExpander" HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch" IsExpanded="True">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE785;" FontSize="14" />
                        <TextBlock Text="Required: open the firewall in the Oracle console" FontWeight="SemiBold" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="8" Padding="0,4,0,4">
                    <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        The app can't do this part — it lives in Oracle's cloud console, not on the server.
                        Do it once:
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                        ☰ → Networking → Virtual Cloud Networks → your VCN → Security Lists →
                        Default Security List → Add Ingress Rules. Add these two (Source CIDR 0.0.0.0/0):
                    </TextBlock>
                    <Border Background="#0A0E13" CornerRadius="8" Padding="10">
                        <TextBlock FontFamily="Consolas" FontSize="12" Foreground="#7EE2B8">
                            Rule 1 — IP Protocol: TCP,  Destination Port Range: 1024-65535<LineBreak/>
                            Rule 2 — IP Protocol: UDP,  Destination Port Range: 1024-65535
                        </TextBlock>
                    </Border>
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                        Opening the whole range is safe: only the relay listens, and ports with no active
                        tunnel have nothing behind them.
                    </TextBlock>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
