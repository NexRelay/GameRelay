# Normalize text; keep platform-correct line endings.
* text=auto eol=lf

# Windows-only scripts stay CRLF
*.ps1  text eol=crlf
*.cmd  text eol=crlf
*.bat  text eol=crlf
*.sln  text eol=crlf

# Shell scripts and unit files MUST be LF (they run on Linux)
*.sh       text eol=lf
*.service  text eol=lf
